# ─────────────────────────────────────────────────────────────────────────────
#  .env.example
#  Copia este archivo como .env y rellena los valores reales.
#  El archivo .env NO debe subirse a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Proyecto ─────────────────────────────────────────────────────────────────
PROJECT_NAME="ClimaSafeAI"
ML_TYPE="supervisado"

# ── Rutas personalizadas (opcional) ──────────────────────────────────────────
# Por defecto el proyecto usa rutas relativas al directorio raíz.
# Descomenta y ajusta si quieres sobreescribirlas.
# DATA_DIR="/ruta/absoluta/a/data"
# MODELS_DIR="/ruta/absoluta/a/models"
# REPORTS_DIR="/ruta/absoluta/a/reports"

# ── Base de datos / almacenamiento externo (si aplica) ───────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mi_base_de_datos
# DB_USER=usuario
# DB_PASSWORD=contraseña_secreta

# ── APIs externas ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# KAGGLE_USERNAME=tu_usuario
# KAGGLE_KEY=tu_clave_kaggle

# ── MLflow / experimentos (opcional) ─────────────────────────────────────────

# MLflow tracking (local por defecto, cambiar a servidor remoto si aplica)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=climasafeai
# Para usar S3 como artifact store:
# MLFLOW_S3_ENDPOINT_URL=https://...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...




# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
