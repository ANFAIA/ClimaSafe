# ── Proyecto ─────────────────────────────────────────────────────────────────
PROJECT_NAME="ClimaSafeAI"
ML_TYPE="supervisado"

# ── APIs externas ─────────────────────────────────────────────────────────────
AEMET_API_KEY=
#Open-Meteo_API_KEY
OpenUV_API_KEY=
# MoMo_API_KEY
# ── Agente scout de papers (opcional) ───────────────────────────────────────

# API key de Gemini para clasificar papers. Sin ella, el scout funciona pero
# clasifica todo como "factor de riesgo" por defecto.
GEMINI_API_KEY=
# Modelo LLM para clasificación (default: gemini-2.0-flash)
# PAPER_SCOUT_MODEL=gemini-2.0-flash

# ── MLflow / experimentos (opcional) ─────────────────────────────────────────

# MLflow tracking (local por defecto, cambiar a servidor remoto si aplica)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=climasafeai
